{
  "$schema": "https://schema.railpack.com",
  "packages": {
    "node": "22",
    "python": "3.12"
  },
  "steps": {
    "install": {
      "commands": ["pip install -r requirements.txt", "cd front && npm ci"]
    },
    "build": {
      "inputs": [{ "step": "install" }],
      "commands": [
        "cd front && npm run build",
        "DJANGO_SETTINGS_MODULE=back.settings.production python back/manage.py collectstatic --noinput"
      ]
    }
  },
  "deploy": {
    "startCommand": "cd back && gunicorn back.wsgi:application --bind 0.0.0.0:$PORT --workers 2 --timeout 120"
  }
}
